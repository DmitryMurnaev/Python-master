# Python master - Environment Configuration
# Скопируйте этот файл в .env и заполните значениями

# Секретный ключ для JWT токенов (сгенерируйте случайную строку)
SECRET_KEY=your-secret-key-here-change-in-production

# Алгоритм для JWT
ALGORITHM=HS256

# Время жизни access токена в минутах
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Режим отладки (True для разработки, False для продакшена)
DEBUG=True

# Название проекта
PROJECT_NAME=Python Master